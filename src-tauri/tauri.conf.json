{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibeisland-linux",
  "version": "0.1.0",
  "identifier": "app.jayisamot.vibeisland-linux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "VibeIsland Linux",
        "width": 400,
        "height": 560,
        "minWidth": 320,
        "minHeight": 120,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false,
        "x": 40,
        "y": 40,
        "shadow": false,
        "acceptFirstMouse": true,
        "focus": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "category": "DeveloperTool",
    "copyright": "Copyright (c) 2026 Jay Isamot",
    "shortDescription": "Supervise AI coding agents from a Linux overlay",
    "longDescription": "VibeIsland Linux is a floating overlay panel that supervises AI coding agents (Claude Code, Codex, Gemini CLI, ...) with approve/deny UI, sound alerts and terminal navigation.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
